# ===== 运行模式 =====
# mapped       = 默认；服务端维护 BOT_ID / BOT_CONFIG，model 是逻辑名
# passthrough  = 纯代理；客户端 Authorization 即 PAT，model 即 bot_id
MODE=mapped

# ===== 上游 =====
# passthrough 模式下留空会自动用 https://api.coze.cn
COZE_API_BASE=https://your-domain.com
COZE_CHAT_PATH=/v3/chat

# 上游必填 user_id（可与业务用户 id 对齐）
COZE_USER_ID=openai-proxy

# ===== mapped 模式配置（passthrough 模式下全部忽略）=====
# 服务端兜底 Coze PAT：客户端未传 Authorization 时使用
COZE_API_KEY=

# 模型→bot 路由
BOT_ID=
DEFAULT_MODEL=coze
BOT_CONFIG={}

# ===== 进程 =====
PORT=38419
# LOG_LEVEL=INFO
# COZE_LOG_SSE=false
# 统一响应协议：非流式 `x_agent`、流式 `agent.event`（Cherry Studio 等请保持关，避免校验报错）
# X_AGENT_PROTOCOL=1
# 或单次请求加头：X-Coze-X-Agent: 1
# 流式 agent.event 条数上限
# X_AGENT_MAX_STREAM_EVENTS=40

# ===== CORS（浏览器跨域访问）=====
# 默认开启；生产建议收紧到具体前端域名
CORS_ENABLED=1
# 全开放（开发联调常用）；若 CORS_ALLOW_CREDENTIALS=1 则不能用 *
CORS_ALLOW_ORIGINS=*
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
# 也支持 JSON 数组：["http://localhost:3000","https://your-frontend.com"]
# 支持子域名（示例：允许 *.example.com）
# CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?example\.com$
# CORS_ALLOW_ORIGIN_REGEX=
# CORS_ALLOW_METHODS=GET,POST,OPTIONS
# CORS_ALLOW_HEADERS=*
# CORS_EXPOSE_HEADERS=
# CORS_ALLOW_CREDENTIALS=0
# CORS_MAX_AGE=600
